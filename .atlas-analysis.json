  "keyFeatures": [
    "Automated AI code review for GitLab MRs and GitHub PRs via webhooks",
    "Distributed runner architecture for isolated review execution",
    "Multi-platform support: GitLab and GitHub integration",
    "Configurable AI review templates, rules, and rating systems",
    "Real-time review results with file-level comments and feedback",
    "Web admin dashboard with review history, trends, and analytics",
    "Notification system supporting Email, Slack, DingTalk, Feishu, WeChat, and browser push",
    "BullMQ-based async task queue with Redis",
    "AI assistant chat interface with session management",
    "System monitoring, logging, backup, and health check endpoints"
  ],
